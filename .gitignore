# 1. 编译构建目录（强制要求使用外部构建）
build/
bin/
out/

# 2. CMake 中间文件（防止误在根目录执行 cmake 产生的污染）
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake
CTestTestfile.cmake
install_manifest.txt

# 3. 编译产物与二进制文件（跨平台兼容）
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out

# 4. 运行时状态与调试转储
*.log
core
core.*

# 5. IDE 与系统环境缓存
.vscode/
.idea/
.DS_Store
*.swp
*.swo
*~